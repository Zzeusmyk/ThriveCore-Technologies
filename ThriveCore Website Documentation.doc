  <tr><td>Frontend</td><td>CSS3</td><td>Styling, layout, animations, responsive design</td></tr>
  <tr><td>Frontend</td><td>Vanilla JavaScript</td><td>Interactivity, form handling, scroll animations</td></tr>
  <tr><td>Backend</td><td>Node.js</td><td>Server runtime environment</td></tr>
  <tr><td>Backend</td><td>Express 5.2</td><td>Web server framework and API routing</td></tr>
  <tr><td>Database</td><td>SQLite (better-sqlite3)</td><td>Contact form submission storage</td></tr>
  <tr><td>Middleware</td><td>CORS</td><td>Cross-origin resource sharing</td></tr>
  <tr><td>Fonts</td><td>Google Fonts</td><td>Poppins (headings) and Inter (body text)</td></tr>
