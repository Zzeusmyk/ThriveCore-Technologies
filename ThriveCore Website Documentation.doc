<h3>5.2 Typography</h3>
<table>
  <tr><th>Element</th><th>Font</th><th>Weight</th><th>Size</th></tr>
  <tr><td>H1 (Hero)</td><td>Poppins</td><td>700</td><td>2.4rem - 3.6rem (responsive)</td></tr>
  <tr><td>H2 (Sections)</td><td>Poppins</td><td>700</td><td>1.8rem - 2.8rem (responsive)</td></tr>
  <tr><td>H3 (Cards)</td><td>Poppins</td><td>700</td><td>1.2rem - 1.5rem (responsive)</td></tr>
  <tr><td>Body text</td><td>Inter</td><td>400</td><td>1rem (16px)</td></tr>
